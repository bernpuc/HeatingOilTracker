<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:HeatingOilTracker.Maui"
             xmlns:converters="clr-namespace:HeatingOilTracker.Maui.Converters"
             x:Class="HeatingOilTracker.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:RangeToColorConverter x:Key="RangeToColorConverter"/>
            
            <Style x:Key="RefSectionTitle" TargetType="Label">
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="#1e293b"/>
                <Setter Property="Margin" Value="0,24,0,8"/>
            </Style>
            <Style x:Key="RefSubTitle" TargetType="Label">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="#334155"/>
                <Setter Property="Margin" Value="0,12,0,4"/>
            </Style>
            <Style x:Key="RefBody" TargetType="Label">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextColor" Value="#475569"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style x:Key="RefFormula" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#f1f5f9"/>
                <Setter Property="Stroke" Value="#e2e8f0"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Margin" Value="0,4,0,10"/>
            </Style>
            <Style x:Key="RefFormulaText" TargetType="Label">
                <Setter Property="FontFamily" Value="Courier New"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextColor" Value="#1e293b"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
